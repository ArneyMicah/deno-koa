{
  "tasks": {
    "dev": "deno run --allow-net --allow-read --allow-env --env-file=.env.development --watch=static,src ./src/main.ts",
    "start": "deno run --allow-net --allow-read --allow-env --env-file=.env.production ./src/main.ts",
    "generate": "deno run -A cli/generate.ts",
    "fmt": "deno fmt",
    "lint": "deno lint",
    "check": "deno check src/main.ts",
    "cache": "deno cache src/main.ts",
    "clean": "deno run -A --eval \"try { Deno.removeSync('dist', { recursive: true }); console.log('✅ dist cleaned'); } catch { console.log('⚠️ no dist to clean'); }\"",
    "compile": "deno task clean && deno compile --allow-net --allow-read --allow-env --env-file=.env.production --output=dist/server ./src/main.ts",
    "compile:win": "deno task clean && deno compile --allow-net --allow-read --allow-env --env-file=.env.production --target=x86_64-pc-windows-msvc --output=dist/server.exe ./src/main.ts",
    "compile:linux": "deno task clean && deno compile --allow-net --allow-read --allow-env --env-file=.env.production --target=x86_64-unknown-linux-gnu --output=dist/server ./src/main.ts",
    "compile:macos": "deno task clean && deno compile --allow-net --allow-read --allow-env --env-file=.env.production --target=x86_64-darwin --output=dist/server ./src/main.ts",
    "build": "deno task compile",
    "build:win": "deno task compile:win",
    "build:linux": "deno task compile:linux",
    "build:macos": "deno task compile:macos"
  },
  "compilerOptions": {
    "strict": true
  },
  "fmt": {
    "lineWidth": 100,
    "indentWidth": 4,
    "singleQuote": false,
    "semiColons": true
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  },
  "imports": {
    "@koa/router": "npm:@koa/router@^15.5.0",
    "@std/path": "jsr:@std/path@^1.1.4",
    "axios": "npm:axios@^1.16.0",
    "koa": "npm:koa@^3.2.0",
    "@koa/cors": "npm:@koa/cors@^5.0.0",
    "koa-bodyparser": "npm:koa-bodyparser@^4.4.1",
    "mysql2": "npm:mysql2@^3.22.3",
    "sequelize": "npm:sequelize@^6.37.8",
    "zod": "npm:zod@^3.23.8",
    "jose": "npm:jose@^5.9.0"
  }
}